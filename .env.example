APP_ENV=local
APP_MODE=mock
MCP_SERVER_NAME=Barrier-Free Mobility MCP
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Auth for our MCP server
# none: local development, static: limited external test, oidc: hosted production
MCP_AUTH_MODE=none
# Legacy compatibility. Used only when MCP_AUTH_MODE is omitted.
MCP_AUTH_ENABLED=false
MCP_API_KEY=change-me
MCP_PUBLIC_BASE_URL=
MCP_OIDC_ISSUER_URL=
MCP_OIDC_JWKS_URL=
MCP_OIDC_AUDIENCE=
MCP_OIDC_ALGORITHM=RS256
MCP_OIDC_REQUIRED_SCOPES=mcp:read
MCP_OIDC_JWKS_SSRF_SAFE=true
MCP_REQUEST_BODY_LIMIT_ENABLED=true
MCP_MAX_REQUEST_BODY_BYTES=1048576
MCP_TOOL_INPUT_MAX_CHARS=120
MCP_RATE_LIMIT_ENABLED=false
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_RATE_LIMIT_WINDOW_SECONDS=60

# Public API keys
PUBLIC_DATA_SERVICE_KEY=
SEOUL_OPEN_API_KEY=
ELEVATOR_STATUS_API_KEY=
ELEVATOR_INFO_API_KEY=
RESTROOM_API_KEY=

# Live public API endpoint URLs. Fill these with the exact URLs from the issued API docs.
FACILITY_API_URL=
FACILITY_API_OPERATIONS=getFcElvtr,getFcEsctr
SHORTEST_ROUTE_API_URL=
SHORTEST_ROUTE_API_OPERATION=getShtrmPath2
ELEVATOR_STATUS_API_URL=
ELEVATOR_INFO_API_URL=
RESTROOM_API_URL=

# Optional live API parameter names. Change these to match each public API document.
FACILITY_STATION_PARAM=station
FACILITY_LINE_PARAM=line
ROUTE_ORIGIN_PARAM=dptreStn
ROUTE_DESTINATION_PARAM=arvlStn
ROUTE_STATION_VALUE_TYPE_PARAM=stationValueType
ROUTE_SEARCH_DATE_PARAM=searchDt
ROUTE_DEFAULT_SEARCH_DATE=
ELEVATOR_STATUS_STATION_PARAM=station
ELEVATOR_STATUS_LINE_PARAM=line
ELEVATOR_INFO_STATION_PARAM=station
ELEVATOR_INFO_LINE_PARAM=line
RESTROOM_STATION_PARAM=station
RESTROOM_LINE_PARAM=line
API_START_INDEX_PARAM=start_index
API_END_INDEX_PARAM=end_index
API_DEFAULT_START_INDEX=1
API_DEFAULT_END_INDEX=1000

# HTTP
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=2
HTTP_RETRY_BACKOFF_SECONDS=0.5
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
HTTP_KEEPALIVE_EXPIRY_SECONDS=30
PUBLIC_API_PAGE_CONCURRENCY=4
FACILITY_QUERY_CONCURRENCY=4

# Cache
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_STALE_TTL_SECONDS=86400
REDIS_SOCKET_TIMEOUT_SECONDS=2.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2.0
ELEVATOR_STATUS_TTL_SECONDS=180
FACILITY_INFO_TTL_SECONDS=86400
ROUTE_TTL_SECONDS=3600
API_FAILURE_TTL_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
